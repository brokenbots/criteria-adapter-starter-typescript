# .gitlab-ci.yml.example — copy to .gitlab-ci.yml to publish from GitLab CI.
#
# Mirrors .github/workflows/publish.yml for users not on GitHub Actions: on a
# tag push, build the single-binary adapter and publish it as a keyless-signed
# OCI artifact via the `criteria` CLI. GitLab's OIDC `id_tokens` supplies
# SIGSTORE_ID_TOKEN, which the CLI uses to sign keyless via Sigstore.
#
# TEMPORARY: the publish stage builds the `criteria` CLI from source (pinned to
# CRITERIA_REF) until the v2 release ships CLI binaries — then replace that step
# with a binary download.

stages:
  - build
  - publish

# 1. Build the adapter binary with its own toolchain (Bun).
build-adapter:
  stage: build
  image: oven/bun:latest
  rules:
    - if: $CI_COMMIT_TAG
  script:
    - bun install
    - bun run build # produces out/adapter
  artifacts:
    paths:
      - out/adapter
    expire_in: 1 hour

# 2. Publish the pre-built binary as a keyless-signed OCI artifact.
publish-adapter:
  stage: publish
  image: golang:1.26
  rules:
    - if: $CI_COMMIT_TAG
  needs:
    - build-adapter
  id_tokens:
    SIGSTORE_ID_TOKEN:
      aud: sigstore
  variables:
    CRITERIA_REF: adapter-v2
  script:
    # TEMPORARY: build the criteria CLI from source until v2 ships release binaries.
    - git clone --depth 1 --branch "$CRITERIA_REF" https://github.com/brokenbots/criteria.git /tmp/criteria
    - (cd /tmp/criteria && go build -o /usr/local/bin/criteria ./cmd/criteria)
    # Give oras the GitLab registry credentials (no docker daemon required).
    - mkdir -p ~/.docker
    - |
      printf '{"auths":{"%s":{"auth":"%s"}}}' "$CI_REGISTRY" \
        "$(printf '%s:%s' "$CI_REGISTRY_USER" "$CI_REGISTRY_PASSWORD" | base64 | tr -d '\n')" \
        > ~/.docker/config.json
    - criteria adapter publish out/adapter --registry "$CI_REGISTRY_IMAGE:${CI_COMMIT_TAG#v}" --keyless
